{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "supabase": {
      "type": "local",
      "command": [
        "/home/fraan/.config/nvm/versions/node/v24.11.1/bin/npx",
        "-y",
        "@supabase/mcp-server-supabase@latest"
      ],
      "environment": {
        "PATH": "/home/fraan/.config/nvm/versions/node/v24.11.1/bin:{env:PATH}",
        "SUPABASE_ACCESS_TOKEN": "{env:SUPABASE_ACCESS_TOKEN}"
      }
    },
    "mcp-mercadopago": {
      "type": "local",
      "command": [
        "/home/fraan/.config/nvm/versions/node/v24.11.1/bin/npx",
        "-y",
        "mcp-remote@latest",
        "https://mcp.mercadopago.com/mcp",
        "--header",
        "Authorization: Bearer {env:MERCADOPAGO_ACCESS_TOKEN}"
      ],
      "environment": {
        "PATH": "/home/fraan/.config/nvm/versions/node/v24.11.1/bin:{env:PATH}"
      }
    }
  }
}
